APP_NAME="ZJSUer Translation Assistant API"
APP_ENV=development
ALLOWED_ORIGINS=["http://localhost:5173"]
DATABASE_PATH=data/zjsuer_translation.sqlite3
AUTH_TOKEN_DAYS=14
SPEECH_PROVIDER=mock
SPEECH_MAX_AUDIO_BYTES=3000000
SPEECH_MAX_TEXT_CHARS=50
# Set SPEECH_PROVIDER=tencent and fill Tencent Cloud credentials to enable real ASR.
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENT_ASR_ENDPOINT=asr.tencentcloudapi.com
TENCENT_ASR_REGION=ap-shanghai
TENCENT_ASR_ENGINE=16k_zh
AI_PROVIDER=mock

# Set AI_PROVIDER=deepseek/openai/dashscope/compatible and fill the matching API key
# to enable real model calls.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_OUTPUT_TOKENS=1200

# Low-cost OpenAI-compatible providers.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Generic OpenAI-compatible Chat Completions endpoint.
COMPATIBLE_API_KEY=
COMPATIBLE_MODEL=deepseek-v4-flash
COMPATIBLE_BASE_URL=https://api.deepseek.com
COMPATIBLE_PROVIDER_NAME=compatible

# Reserved for future provider integrations.
QIANFAN_API_KEY=
