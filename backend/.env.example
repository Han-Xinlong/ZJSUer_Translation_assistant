APP_NAME="ZJSUer Translation Assistant API"
APP_ENV=development
ALLOWED_ORIGINS=["http://localhost:5173"]
AI_PROVIDER=mock

# Set AI_PROVIDER=openai and fill OPENAI_API_KEY to enable real model calls.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_OUTPUT_TOKENS=1200

# Reserved for future provider integrations.
QIANFAN_API_KEY=
DASHSCOPE_API_KEY=
