APP_ENV=production
AI_PROVIDER=mock

# Use same-origin requests through the gateway.
# Replace SERVER_PUBLIC_HOST with http://your-server-public-ip or https://your-domain after you have one.
PUBLIC_ORIGIN=http://SERVER_PUBLIC_HOST
ALLOWED_ORIGINS=["http://SERVER_PUBLIC_HOST"]

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_OUTPUT_TOKENS=1200

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

COMPATIBLE_API_KEY=
COMPATIBLE_MODEL=deepseek-v4-flash
COMPATIBLE_BASE_URL=https://api.deepseek.com
COMPATIBLE_PROVIDER_NAME=compatible

QIANFAN_API_KEY=
